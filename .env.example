# Environment Variables for DSPy RAG Project
# Copy this file to .env and fill in your actual values

# Anthropic API Key (required for DSPy to work with Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Weaviate Configuration (required for vector database connectivity)
# IMPORTANT: Use the actual cluster URL, NOT the console page URL
#
# Based on your cluster UUID (acb13d12-5c36-4253-9d71-746717093f80),
# your URL is MOST LIKELY one of these:
#   https://acb13d12-5c36-4253-9d71-746717093f80.weaviate.network
#   OR
#   https://your-cluster-name-acb13d12.wcs.api.weaviate.cloud
#
# To find the exact URL:
# 1. Go to https://console.weaviate.cloud/cluster-details/acb13d12-5c36-4253-9d71-746717093f80
# 2. Look for "Cluster URL", "REST Endpoint", or "Connection Details" section
# 3. Copy the URL shown there (it will NOT have "console.weaviate.cloud" in it)
#
# See find_weaviate_url.md for detailed instructions
WEAVIATE_URL=https://acb13d12-5c36-4253-9d71-746717093f80.weaviate.network
WEAVIATE_API_KEY=your-weaviate-api-key-here

# Optional: Uncomment if using other services
# OPENAI_API_KEY=your-openai-api-key-here
# HUGGINGFACE_API_KEY=your-huggingface-api-key